# ============================================================
# Ascended Unified Database — Environment Variables Template
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ============================================================

# ---- Environment ----
ENVIRONMENT=dev

# ---- JWT Auth ----
JWT_SECRET_KEY=

# ---- PostgreSQL ----
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=ascended_dev
POSTGRES_USER=postgres
POSTGRES_PASSWORD=

# ---- Redis ----
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ---- MinIO (Dev Object Storage) ----
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=ascended-dev

# ---- AWS S3 (Prod / Enterprise Object Storage) ----
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET=ascended-prod

# ---- Qdrant ----
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_API_KEY=

# ---- Neo4j ----
NEO4J_HOST=neo4j
NEO4J_PORT=7687
NEO4J_DB=neo4j
NEO4J_PASSWORD=

# ---- ClickHouse ----
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_PORT=8123
CLICKHOUSE_DB=ascended
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

# ---- Kafka / Redpanda ----
KAFKA_BROKERS=kafka:9092
KAFKA_TOPIC_PREFIX=ascended

# ---- OpenTelemetry ----
OTEL_EXPORTER_OTLP_ENDPOINT=

# ---- Grafana ----
GRAFANA_ADMIN_PASSWORD=

# ---- Container Registry ----
REGISTRY_URL=
REGISTRY_USERNAME=
REGISTRY_PASSWORD=

# ---- Kubernetes ----
# DEV_KUBECONFIG=  # base64-encoded kubeconfig
# PROD_KUBECONFIG=
# ENTERPRISE_KUBECONFIG=
